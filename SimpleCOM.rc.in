#pragma code_page(65001)
#include <windows.h>

#define VER_FILEVERSION             @SIMPLECOM_VERSION_MAJOR@,@SIMPLECOM_VERSION_MINOR@,@SIMPLECOM_VERSION_PATCH@,@SIMPLECOM_VERSION_TWEAK@
#define VER_FILEVERSION_STR         "@SIMPLECOM_VERSION_MAJOR@.@SIMPLECOM_VERSION_MINOR@.@SIMPLECOM_VERSION_PATCH@.@SIMPLECOM_VERSION_TWEAK@"

#define VER_PRODUCTVERSION          @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@SIMPLECOM_VERSION_TWEAK@
#define VER_PRODUCTVERSION_STR      "@SIMPLECOM_VERSION_MAJOR@.@SIMPLECOM_VERSION_MINOR@.@SIMPLECOM_VERSION_PATCH@.@SIMPLECOM_VERSION_TWEAK@"

#define VER_COMPANYNAME_STR         "SimpleCOM Technology Co., Ltd."
#define VER_FILEDESCRIPTION_STR     "SimpleCOM Library"
#define VER_INTERNALNAME_STR        "SimpleCOM"
#define VER_LEGALCOPYRIGHT_STR      "Copyright (C) @COPYRIGHT_YEAR@ SimpleCOM Technology Co., Ltd."
#define VER_ORIGINALFILENAME_STR    "SimpleCOM.dll"
#define VER_PRODUCTNAME_STR         "SimpleCOM Automation System"
#define VER_BUILDDATE_STR           "@BUILD_DATE@"

VS_VERSION_INFO VERSIONINFO
FILEVERSION     VER_FILEVERSION
PRODUCTVERSION  VER_PRODUCTVERSION
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0x0L
FILEOS          VOS__WINDOWS32
FILETYPE        VFT_DLL
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      VER_COMPANYNAME_STR
            VALUE "FileDescription",  VER_FILEDESCRIPTION_STR
            VALUE "FileVersion",      VER_FILEVERSION_STR
            VALUE "InternalName",     VER_INTERNALNAME_STR
            VALUE "LegalCopyright",   VER_LEGALCOPYRIGHT_STR
            VALUE "OriginalFilename", VER_ORIGINALFILENAME_STR
            VALUE "ProductName",      VER_PRODUCTNAME_STR
            VALUE "ProductVersion",   VER_PRODUCTVERSION_STR
            VALUE "BuildDate",        VER_BUILDDATE_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

1 TYPELIB "@IDL_OUTPUT_TLB@"